generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
}

enum CustomerStatus {
  UNTOUCHED
  IN_PROGRESS
  WORKED
  LOST
}

enum ActivityType {
  VISIT
  CALL
  EMAIL
  WHATSAPP
}

enum QuoteResult {
  PENDING
  WON
  LOST
}

enum CategoryType {
  CLASS1
  CLASS2
  PRODUCT
  LANE
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum JobStatus {
  INQUIRY
  QUOTED
  BOOKED
  IN_TRANSIT
  CUSTOMS
  DELIVERED
  CANCELLED
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

model Office {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  companies Company[]
  activities Activity[]
  quotes Quote[]
  shipments ShipmentRecord[]
  documents CompanyDocument[]
  laneRates LaneRate[]
  marginProfiles MarginProfile[]
  inquiries Inquiry[]
  jobs         Job[]
  jobDocuments JobDocument[]
  emailAccounts EmailAccount[]
  emailThreads  EmailThread[]
  assignmentChanges AssignmentChange[]
  events    Event[]
  categories CategoryOption[]
  tasks Task[]
  riskAlerts RiskAlert[]
  savedViews SavedView[]

  @@unique([name])
}

model SavedView {
  id        String   @id @default(cuid())
  officeId  String
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId, userId, createdAt])
  @@unique([officeId, userId, name])
}

model CategoryOption {
  id        String       @id @default(cuid())
  officeId  String
  type      CategoryType
  value     String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([officeId, type, value])
  @@index([officeId, type, isActive])
}

model User {
  id           String   @id @default(cuid())
  officeId     String
  email        String
  passwordHash String
  fullName     String
  role         UserRole @default(SALES)
  isActive     Boolean  @default(true)
  canViewWholeOffice Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  ownedCompanies        CompanyOwner[]
  activitiesCreated     Activity[]     @relation("ActivityCreatedBy")
  assignmentChangesMade AssignmentChange[] @relation("AssignmentChangedBy")

  @@unique([officeId, email])
  @@index([officeId, role])
}

model Company {
  id        String         @id @default(cuid())
  officeId  String
  name      String
  status    CustomerStatus @default(UNTOUCHED)

  // Category values (one per category for MVP)
  class1     String? // Passive / Potential / Active
  class2     String? // A-E
  product    String? // Sea / Air / Road / LTL / Project (MVP: single)
  lane       String? // Region e.g., "Mediterranean", "America", "Europe"
  direction  String? // Import / Export / Both

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  contacts   Contact[]
  owners     CompanyOwner[]
  activities Activity[]
  quotes     Quote[]
  shipments  ShipmentRecord[]
  documents  CompanyDocument[]
  assignmentChanges AssignmentChange[]
  tasks Task[]
  riskAlerts RiskAlert[]
  jobs       Job[]
  inquiries  Inquiry[]

  @@unique([officeId, name])
  @@index([officeId, status])
  @@index([officeId, class1])
  @@index([officeId, class2])
  @@index([officeId, product])
  @@index([officeId, lane])
}

model Contact {
  id        String  @id @default(cuid())
  companyId String
  fullName  String
  title     String?
  email     String?
  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Multiple owners per company (requested)
model CompanyOwner {
  id        String @id @default(cuid())
  companyId String
  userId    String
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model Activity {
  id        String       @id @default(cuid())
  officeId  String
  companyId String
  type      ActivityType
  occurredAt DateTime    @default(now())

  subject   String?
  body      String?
  audioUrl  String?

  createdByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office  Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([officeId, companyId, occurredAt])
  @@index([officeId, type, occurredAt])
}

model Quote {
  id        String      @id @default(cuid())
  officeId  String
  companyId String
  result    QuoteResult @default(PENDING)
  origin    String?     // e.g. Istanbul, TR
  destination String?   // e.g. Hamburg, DE
  mode      String?     // AIR / SEA-FCL / SEA-LCL / ROAD / COURIER
  value     Float?
  currency  String?     // e.g. USD, EUR, TRY
  notes     String?
  lostReason String?    // Price / Competitor / No volume / Wrong lane / Other
  quotedAt  DateTime    @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office  Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([officeId, companyId, quotedAt])
  @@index([officeId, result, quotedAt])
}

// Assignment changes log (audit trail)
model AssignmentChange {
  id        String   @id @default(cuid())
  officeId  String
  companyId String
  changedByUserId String?
  createdAt DateTime @default(now())

  // JSON snapshot for MVP simplicity (who added/removed; primary changes, etc.)
  diff Json

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  changedBy User? @relation("AssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([officeId, companyId, createdAt])
}

// Generic event table for future risk signals / phase2 integrations
model Event {
  id        String   @id @default(cuid())
  officeId  String
  type      String
  entityType String?
  entityId  String?
  payload   Json
  createdAt DateTime @default(now())

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId, type, createdAt])
  @@index([officeId, entityType, entityId])
}

model Task {
  id        String     @id @default(cuid())
  officeId  String
  companyId String
  title     String
  details   String?
  dueAt     DateTime?
  status    TaskStatus @default(OPEN)
  assignedToUserId String?
  createdByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([officeId, status, dueAt])
  @@index([companyId, status])
}

model RiskAlert {
  id        String    @id @default(cuid())
  officeId  String
  companyId String
  level     RiskLevel
  reason    String
  isOpen    Boolean   @default(true)
  resolvedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([officeId, isOpen, level, createdAt])
  @@index([companyId, isOpen])
}

model CompanyDocument {
  id          String   @id @default(cuid())
  officeId    String
  companyId   String
  name        String
  url         String
  docType     String?  // contract / invoice / proposal / other
  uploadedByUserId String?
  createdAt   DateTime @default(now())

  office  Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([officeId, companyId, createdAt])
}

// ── Pricing module ────────────────────────────────────────────────────────

model LaneRate {
  id          String   @id @default(cuid())
  officeId    String
  origin      String   // e.g. Istanbul
  destination String   // e.g. Hamburg
  mode        String   // AIR / SEA-FCL / SEA-LCL / ROAD / COURIER
  baseAmount  Float
  currency    String   @default("USD")
  validFrom   DateTime @default(now())
  validTo     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId, origin, destination, mode])
}

model MarginProfile {
  id            String  @id @default(cuid())
  officeId      String
  label         String  // e.g. "New client", "Existing – standard", "Urgent"
  customerTier  String? // new / existing / vip
  urgency       String? // normal / asap / flexible
  marginPercent Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
}

model Inquiry {
  id            String   @id @default(cuid())
  officeId      String
  companyId     String?
  subject       String
  fromEmail     String?
  fromCompany   String?
  origin        String?
  destination   String?
  mode          String?  // AIR / SEA-FCL / SEA-LCL / ROAD / COURIER
  containerType String?  // 20GP / 40HC / 40DRY / 20DRY etc.
  commodity     String?
  weight        Float?
  volume        Float?
  incoterms     String?
  cargoReadyDate DateTime?
  type          String   @default("FORWARDING") // FORWARDING (move customer's cargo) | SOURCING (find + buy a commodity for customer)
  status        String   @default("INGESTED") // INGESTED / PARSED / PRICED / QUOTED / WON / LOST
  rawEmailBody  String?
  parsedData    String?  // JSON: AI-extracted fields
  notes         String?
  receivedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  office        Office        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  carrierQuotes CarrierQuote[]
  job           Job?
  emailThreads  EmailThread[]

  @@index([officeId, status, receivedAt])
  @@index([officeId, companyId])
}

model CarrierQuote {
  id          String   @id @default(cuid())
  inquiryId   String
  carrier     String
  quoteType   String   @default("EMAIL") // API / EMAIL
  rateName    String?
  total20     Float?
  total40     Float?
  total40HC   Float?
  transitDays Int?
  service     String?
  validity    String?
  transshipments String?
  status      String   @default("PENDING") // PENDING / RECEIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

// Shipment history — populated from Siber in Phase 2, or manually entered
model ShipmentRecord {
  id          String   @id @default(cuid())
  officeId    String
  companyId   String
  origin      String?
  destination String?
  mode        String?  // AIR / SEA-FCL / SEA-LCL / ROAD / COURIER
  weight      Float?   // kg
  volume      Float?   // cbm
  revenue     Float?
  profit      Float?
  currency    String?  @default("USD")
  shipmentDate DateTime
  reference   String?  // Siber / carrier reference number
  source      String   @default("manual") // "siber" | "manual"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office  Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([officeId, companyId, shipmentDate])
  @@index([officeId, shipmentDate])
}

// ── Jobs (forwarding operations) ─────────────────────────────────────────────

model Job {
  id               String    @id @default(cuid())
  officeId         String
  companyId        String?
  assignedToUserId String?
  inquiryId        String?   @unique  // set when converted from an Inquiry

  reference        String    // e.g. JOB-2025-001
  status           JobStatus @default(INQUIRY)
  type             String    @default("FORWARDING")  // FORWARDING | SOURCING
  mode             String?   // AIR / SEA-FCL / SEA-LCL / ROAD / COURIER
  origin           String?
  destination      String?
  commodity        String?
  incoterms        String?
  weight           Float?    // kg
  volume           Float?    // cbm
  packages         Int?

  etd              DateTime?
  eta              DateTime?

  revenue          Float?
  cost             Float?
  currency         String    @default("USD")

  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  office       Office        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  inquiry      Inquiry?      @relation(fields: [inquiryId], references: [id])
  documents    JobDocument[]
  milestones   JobMilestone[]
  emailThreads EmailThread[]

  @@unique([officeId, reference])
  @@index([officeId, status, createdAt])
  @@index([officeId, companyId])
}

model JobDocument {
  id               String   @id @default(cuid())
  jobId            String
  officeId         String
  name             String
  url              String?
  docType          String   // BL / INVOICE / PACKING_LIST / COO / CUSTOMS / BOOKING / OTHER
  status           String   @default("PENDING") // PENDING / UPLOADED / APPROVED
  uploadedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([officeId, docType])
}

model JobMilestone {
  id        String    @id @default(cuid())
  jobId     String
  type      String    // BOOKING / ETD / ETA / CUSTOMS_ENTRY / CUSTOMS_RELEASE / DELIVERY
  plannedAt DateTime?
  actualAt  DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, type])
}

// ── Email integration ─────────────────────────────────────────────────────────

model EmailAccount {
  id           String    @id @default(cuid())
  officeId     String
  email        String
  provider     String    // GMAIL / OUTLOOK / IMAP
  accessToken  String?
  refreshToken String?
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  office   Office         @relation(fields: [officeId], references: [id], onDelete: Cascade)
  messages EmailMessage[]

  @@unique([officeId, email])
  @@index([officeId])
}

model EmailThread {
  id               String   @id @default(cuid())
  officeId         String
  jobId            String?
  inquiryId        String?
  subject          String
  participants     String   // JSON array of email addresses
  externalThreadId String?  // provider thread id (Gmail threadId) for direct mapping on resync
  autoLinkedAt     DateTime? // when we last attempted auto-link / auto-inquiry
  autoLinkSkipReason String? // why AI decided not to auto-create an inquiry (e.g. "not freight related")
  lastMessageAt    DateTime @default(now())
  messageCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  office   Office         @relation(fields: [officeId], references: [id], onDelete: Cascade)
  job      Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  inquiry  Inquiry?       @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  messages EmailMessage[]

  @@index([officeId, jobId])
  @@index([officeId, inquiryId])
  @@index([officeId, lastMessageAt])
  @@index([officeId, externalThreadId])
}

model EmailMessage {
  id         String         @id @default(cuid())
  threadId   String
  accountId  String?
  externalId String?        // provider message-id for dedup
  direction  EmailDirection
  fromEmail  String
  fromName   String?
  toEmails   String         // JSON array
  ccEmails   String?        // JSON array
  subject    String?
  bodyText   String?
  bodyHtml   String?
  attachments String?       // JSON array {name, url, mimeType, size}
  sentAt     DateTime       @default(now())
  isRead     Boolean        @default(false)
  classification     String?  // RFQ | CARRIER_REPLY | CUSTOMER_REPLY | RELATED_NOTE | OTHER (set by AI on inbound)
  classificationReason String?  // one-line AI explanation
  classificationAt   DateTime?  // when the classifier last ran
  createdAt  DateTime       @default(now())

  thread  EmailThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  account EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([externalId])
  @@index([threadId, sentAt])
  @@index([accountId, sentAt])
}
